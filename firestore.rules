rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'credits', 'createdAt']) &&
             data.keys().size() >= 4 &&
             data.uid is string && data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256 &&
             data.credits is number && data.credits >= 0 &&
             data.createdAt == request.time;
    }

    function isValidTransformation(data) {
      return data.keys().hasAll(['userId', 'resultImage', 'createdAt']) &&
             data.userId == request.auth.uid &&
             // Limit image string size to prevent denial of wallet (though resultImage is usually a URL)
             data.resultImage is string && data.resultImage.size() <= 2000 &&
             data.createdAt == request.time;
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['userId', 'orderId', 'status', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.orderId is string && data.orderId.size() <= 128 &&
             data.status in ['pending', 'completed', 'failed'] &&
             data.createdAt == request.time;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && 
                    isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'email']);
    }

    match /transformations/{transId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(transId) && isValidTransformation(incoming());
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    match /transactions/{txnId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(txnId) && isValidTransaction(incoming());
    }

    match /shares/{shareId} {
      allow get: if true;
      allow create: if isSignedIn() && isValidId(shareId) && isValidTransformation(incoming());
    }
  }
}
